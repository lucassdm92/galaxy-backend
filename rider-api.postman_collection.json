              "raw": "{{baseUrl}}/api/rider/1/delivery/1/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "delivery", "1", "accept"]
            }
          }
        },
        {
          "name": "Refuse Delivery",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1/delivery/1/refuse",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "delivery", "1", "refuse"]
            }
          }
        },
        {
          "name": "Collect Delivery",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1/delivery/1/collect",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "delivery", "1", "collect"]
            }
          }
        },
        {
          "name": "Deliver Delivery",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1/delivery/1/deliver",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "delivery", "1", "deliver"]
            }
          }
        },
        {
          "name": "Get Rider Delivery History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "history"]
            }
          }
        }
      ]
    },
    {
      "name": "Delivery",
      "item": [
        {
          "name": "Request Delivery",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/delivery/request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "delivery", "request"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price_calculation_id\": 1,\n  \"client_id\": 1,\n  \"origin\": \"123 Main Street, Dublin\",\n  \"destination\": \"456 Oak Avenue, Dublin\",\n  \"customer_name\": \"John Doe\",\n  \"customer_phone\": \"+353 87 123 4567\",\n  \"customer_note\": \"Leave at the door\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Pending Deliveries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/delivery/pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "delivery", "pending"]
            }
          }
        },
        {
          "name": "List Deliveries by Client",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/delivery/client/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "delivery", "client", "1"]
            }
          }
        },
        {
          "name": "List Deliveries by Rider",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/delivery/myDelivery/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "delivery", "myDelivery", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Price",
      "item": [
        {
          "name": "Get Current Price",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/prices/current",
              "host": ["{{baseUrl}}"],
              "path": ["api", "prices", "current"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": \"123 Main Street, Dublin\",\n  \"destination\": \"456 Oak Avenue, Dublin\",\n  \"date\": \"2026-03-31T10:00:00\",\n  \"user_ip\": \"127.0.0.1\",\n  \"clientId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "WebSocket",
      "item": [
        {
          "name": "Listen - New Delivery (Raw)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "ws://localhost:8080/ws-raw",
              "protocol": "ws",
              "host": ["localhost"],
              "port": "8080",
              "path": ["ws-raw"]
            }
          },
          "description": "Conecta e recebe notificações de novos deliveries em tempo real. Não precisa enviar nada."
        }
      ]
    }
  ]
}

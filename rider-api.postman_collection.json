{
  "info": {
    "name": "GalaxyBck - API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/user/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john.doe\",\n  \"email\": \"john.doe@email.com\",\n  \"password\": \"secret123\",\n  \"created_by\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Client",
      "item": [
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/client/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "client", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"+353 87 123 4567\",\n  \"address\": \"123 Main Street, Dublin\",\n  \"vat\": \"IE1234567T\",\n  \"user_id\": 1,\n  \"created_by\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Client by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/client/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "client", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Rider",
      "item": [
        {
          "name": "Register Rider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/rider/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"+353 87 123 4567\",\n  \"address\": \"123 Main Street, Dublin\",\n  \"vehicle_type\": \"BICYCLE\",\n  \"vehicle_plate\": null,\n  \"identification_document\": \"PA1234567\",\n  \"drive_license\": \"DL9876543\",\n  \"vat_number\": \"1234567T\",\n  \"vat\": \"IE1234567T\",\n  \"rider_type\": \"STUDENT\",\n  \"email\": \"john.doe@email.com\",\n  \"password\": \"secret123\",\n  \"created_by\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Rider by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1"]
            }
          }
        },
        {
          "name": "List All Riders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider"]
            }
          }
        },
        {
          "name": "Toggle Active",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/rider/1/toggle-active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rider", "1", "toggle-active"]
            }
          }
        },
        {
          "name": "Accept Delivery",
          "request": {
            "method": "POST",
            "header": [],
